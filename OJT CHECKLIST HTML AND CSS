<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OJTrack PH - CLOCK IN/OUT</title>
    <link rel="stylesheet" href="ojtattendance.css">
</head>
<body>

    <div class="dashboard-container">

        <div class="top-content">
            
           <header class="dashboard-header">
            <div class="company-header"> 
                <a href="index.html">
                    <img src="../all pov/images/633412968_1977516346287127_5918068733792267466_n.jpg">
                </a>
            <h1 class="site-title">OJTrack PH</h1>
        </div>

            <div class="header-tools">
                <div class="search-bar">
                    <input type="text" placeholder="Search">
                    <span class="search-icon">🔍</span>
                </div>
                
                <nav class="header-icons">
                    <a href="#" id="msg-icon" title="Messages">✉️</a>
                    <a href="#" id="notif-icon" title="Notifications">🔔</a>
                    <a href="#" id="cal-icon" title="Calendar">📅</a> 
                    <a href="account.html" title="Profile">👤</a>
                </nav>

            </div>
        </header>

        <main class="tracker-main">
        <div class="main-banner">
            <h2>OJT Clock In and Clock Out</h2>
        </div>

        <div class="tracker-grid">
            <section class="log-section">
                <div class="log-card">
                    <div class="card-header">
                        <span class="icon">📅</span> Sunday, February 22, 2026
                    </div>
                    
                    <form class="attendance-form">
                        <div class="time-container">
                            <div class="time-box">
                                <label>TIME IN</label>
                                <div class="digital-clock">
                                    <div class="unit"><span>HOUR</span><div class="num">00</div></div>
                                    <span class="colon">:</span>
                                    <div class="unit"><span>MINUTE</span><div class="num">00</div></div>
                                    <div class="ampm-toggle"><span>AM/PM</span><div class="btn-blue">AM</div></div>
                                </div>
                            </div>
                            <div class="time-box">
                                <label>TIME OUT</label>
                                <div class="digital-clock">
                                    <div class="unit"><span>HOUR</span><div class="num">00</div></div>
                                    <span class="colon">:</span>
                                    <div class="unit"><span>MINUTE</span><div class="num">00</div></div>
                                    <div class="ampm-toggle"><span>AM/PM</span><div class="btn-blue">AM</div></div>
                                </div>
                            </div>
                        </div>

                        <div class="upload-area">
                            <p>Attach Documents (Optional)</p>
                            <label class="file-label">
                                <span class="icon">📤</span> Choose File
                                <input type="file" hidden>
                            </label>
                        </div>

                        <button type="submit" class="submit-log-btn">
                            <span class="icon">🕒</span> Submit Log
                        </button>
                    </form>
                </div>

                <div class="status-table">
                    No attendance records yet
                </div>
            </section>

            <aside class="tracker-sidebar">
                <div class="side-widget calendar-card">
                    <h4>CALENDAR</h4>
                    <p>February 2026</p>
                    <div class="cal-mini-grid">
                        <div class="day active-day">22</div>
                    </div>
                </div>

                        <div class="side-widget summary-card">
                            <h4>Summary</h4>
                            <p>Total Days Logged</p>
                            <div class="big-stat">0</div>
                            <span class="stat-icon">📅</span>
                        </div>
                    </aside>
                </div>
            </main>
        </div>
    </div>

</body>
</html>

:root {
    --bg-dark: #4c4c4c;
    --header-bg: #373737;
    --brand-yellow: #ffd400;
    --brand-blue: #3b5998;
    --widget-bg: #8c8c8c;
    --text-white: #ffffff;
}

* { 
    margin: 0; 
    padding: 0; 
    box-sizing: 
    border-box; 
    font-family: Arial, sans-serif; 
}

body { 
    background-color: var(--bg-dark); 
    color: var(--text-white); 
}

.dashboard-header {
    background-color: var(--header-bg);
    padding: 10px 25px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap:10px;
}

.company-header { 
    display: flex; 
    align-items: center; 
    gap: 10px; 
}

.company-header img { 
    width: 45px;
     border-radius: 8px; 
}

.site-title { 
    color: var(--brand-yellow); 
    font-size: 1.8rem; 
}

.header-tools { 
    display: flex; 
    align-items: center; 
    gap: 20px; 
}

.search-bar { 
    position: relative; 
}

.search-bar { 
    position: relative; 
}

.search-bar input {
    padding: 8px 30px 8px 15px;
    border-radius: 20px;
    border: none;
}

.search-icon { 
    position: absolute; 
    right: 10px; 
    top: 7px; 
    color: #333; 
}

.header-icons a { 
    text-decoration: none; 
    font-size: 1.2rem; 
    color: var(--brand-yellow); 
    margin-left: 10px; 
}

.tracker-main {
    padding: 20px;
    background-color: #4a4a4a;
    min-height: 100vh;
}

.main-banner {
    background-color: #3b5998;
    color: #ffcc00;
    text-align: center;
    padding: 15px;
    border-radius: 8px;
    border: 2px solid #000;
    margin-bottom: 20px;
    font-weight: bold;
}

.tracker-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
}

.log-card {
    background-color: #333;
    border: 2px solid #000;
    border-radius: 12px;
    padding: 20px;
}

.card-header {
    color: white;
    border-bottom: 1px solid #555;
    padding-bottom: 10px;
    margin-bottom: 20px;
}

.time-container {
    display: flex;
    gap: 20px;
    margin-bottom: 25px;
}

.time-box {
    flex: 1;
    background: #444;
    padding: 15px;
    border-radius: 10px;
    border: 2px solid #000;
}

.time-box label {
    color: #ccc;
    font-size: 0.8rem;
    display: block;
    margin-bottom: 10px;
}

.digital-clock {
    display: flex;
    align-items: center;
    justify-content: space-around;
}

.unit span {
    font-size: 0.6rem;
    color: #ffcc00;
    display: block;
    text-align: center;
}

.num, .btn-blue {
    background: #222;
    color: white;
    padding: 10px;
    border-radius: 5px;
    border: 1px solid #ffcc00;
    font-weight: bold;
    font-size: 1.2rem;
}

.btn-blue { 
    background: #3b5998; 
    cursor: 
    pointer; 
}

.file-label, .submit-log-btn {
    display: block;
    width: 100%;
    padding: 12px;
    text-align: center;
    border-radius: 8px;
    border: 2px solid #000;
    margin-top: 15px;
    cursor: pointer;
    font-weight: bold;
}

.file-label { background: #555; color: #ffcc00; }
.submit-log-btn { background: #444; color: #888; border-color: #555; }

.status-table {
    background: #555;
    color: #aaa;
    text-align: center;
    padding: 20px;
    border-radius: 8px;
    border: 2px solid #000;
    margin-top: 20px;
}

.side-widget {
    background: #333;
    border: 2px solid #000;
    border-radius: 10px;
    padding: 15px;
    margin-bottom: 20px;
    color: white;
}

.calendar-card h4, .summary-card h4 {
    color: #ffcc00;
    margin-bottom: 10px;
}

.summary-card { background: #3b5998; }
.big-stat { font-size: 3rem; font-weight: bold; color: #ffcc00; }
.active-day { 
    background: #ffcc00; 
    color: black; 
    border-radius: 50%; 
    width: 30px; 
    height: 30px; 
    display: flex; 
    align-items: center; 
    justify-content: center;
}
