<!DOCTYPE html>
<html lang="en">
<head>
    <title>OJTrack PH - LOGIN</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="login.css">
</head>

<body>

<div class="page-container">
    
    <header class="site-header">
        <div class="company-header">
            <img src="images/633412968_1977516346287127_5918068733792267466_n.jpg" class="header-logo">
            <h1>OJTrack PH</h1>
        </div>
    </header>

    
    <main class="login-content">

        <section class="login-card">

            <h2>WELCOME TO</h2>
            <div class="logo">
                <img src="images/610551570_1263199728988936_4834396701990071248_n-removebg-preview.png">
            </div>

                <div class="button-group">
                <a href="loginproper.html">
                <button class="btn-login">LOG IN </button>
                </a>

                <a href="loginproper.html">
                <button class="btn-adminlogin">ADMIN LOG IN</button>
                </a>  
                
                <button class="register">
                    No account? <a href="register.html">Register HERE</a>
                </button>
                </a>
                </div>  

        </section>

    </main>

    // CSS

    * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

body {
    background: #4c4c4c;
    color: white;
}

.site-header {
    background: #373737;
    padding: 10px 25px;
}

.company-header {
    display: flex;
    align-items: center;
    gap: 10px;
}

.header-logo {
    width: 40px;
}

.company-header h1 {
    color: #ffd400;
}

.login-content {
    display: flex;
    justify-content: center;
    align-items: center;
    height: calc(100vh - 60px);
}

.login-card {
    background: #1f1f1f;
    width: 320px;
    padding: 30px;
    border-radius: 12px;
    text-align: center;
    box-shadow: 0 0 20px rgba(0,0,0,.5);
}

.login-card h2 {
    color: #ffd400;
    margin-bottom: 15px;
    letter-spacing: 2px;
}

.logo img {
    align-items: center;
    margin-right: 200%;
    max-width: 100%; 
    height: auto;
}

.button-group {
  display: flex;
  flex-direction: column; 
  gap: 15px;              
  align-items: center;    
  margin-top: 20px;
}

.button-group a {
  width: 85%;            
  text-decoration: none;  
}

.button-group button {
  width: 100%;
  padding: 12px;
  border-radius: 50px;
  border: none;
  font-weight: bold;
  cursor: pointer;
  font-size: 16px;
}

.btn-login {
  background-color: yellow; 
  color: black;
}

.btn-adminlogin {
  background-color: #4169E1; 
  color: white;
}

.register {
    padding: 12px;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    font-size: 10px;
}

.register a {
    color: black;
    text-decoration: none;
    font-weight: bold;
}


</div>

</body>
</html>
